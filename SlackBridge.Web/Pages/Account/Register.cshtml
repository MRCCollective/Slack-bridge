@page
@model SlackBridge.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Create account";
}

<div class="auth-panel mx-auto">
    <h1>Create account</h1>
    <p class="text-muted">Start on the free plan. No payment details needed.</p>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.CompanyName" class="form-label"></label>
            <input asp-for="Input.CompanyName" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
        </div>
        <button class="btn btn-primary w-100" type="submit">Create account</button>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
