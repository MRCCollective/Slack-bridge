@page
@model SlackBridge.Web.Pages.Admin.Usage.IndexModel
@{
    ViewData["Title"] = "Usage";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="mb-1">Usage</h1>
        <p class="text-muted mb-0">Current plan limits and monthly event volume.</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="metric-card p-3">
            <div class="metric-label">Plan</div>
            <div class="metric-value">@Model.Snapshot.Plan</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card p-3">
            <div class="metric-label">Events this month</div>
            <div class="metric-value">@Model.Snapshot.EventsSentThisMonth / @Model.Snapshot.Limits.EventsPerMonth</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card p-3">
            <div class="metric-label">Projects</div>
            <div class="metric-value">@Model.Snapshot.ProjectCount / @Model.Snapshot.Limits.Projects</div>
        </div>
    </div>
</div>

<div class="mt-3 metric-card p-3">
    <div class="metric-label">API keys</div>
    <div class="metric-value">@Model.Snapshot.ApiKeyCount / @Model.Snapshot.Limits.ApiKeys</div>
</div>
