@page
@model SlackBridge.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="mb-1">Users</h1>
        <p class="text-muted mb-0">Superuser view of accounts and their tenant workspaces.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<table class="table table-striped align-middle">
    <thead>
    <tr>
        <th>Email</th>
        <th>Tenant</th>
        <th>Tenant id</th>
        <th>Roles</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model.Users)
    {
        <tr>
            <td>@user.Email</td>
            <td>@user.CompanyName</td>
            <td>@user.CustomerInstanceId</td>
            <td>@user.Roles</td>
            <td class="text-end">
                @if (user.IsCurrentUser)
                {
                    <span class="text-muted">Current user</span>
                }
                else if (user.IsSuperUser)
                {
                    <span class="text-muted">Protected</span>
                }
                else
                {
                    <form method="post" asp-page-handler="Tenant" asp-route-id="@user.Id" class="tenant-action d-inline-flex">
                        <select name="customerInstanceId" class="form-select form-select-sm" aria-label="Tenant">
                            @foreach (var tenant in Model.Tenants)
                            {
                                <option value="@tenant.Id" selected="@(tenant.Id == user.CustomerInstanceId)">
                                    @tenant.CompanyName (#@tenant.Id)
                                </option>
                            }
                        </select>
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Update</button>
                    </form>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="d-inline">
                        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
