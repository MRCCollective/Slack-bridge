@page
@model SlackBridge.Web.Pages.Admin.ApiKeys.IndexModel
@{
    ViewData["Title"] = "API Keys";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>API Keys</h1>
    <a class="btn btn-primary" asp-page="Create">New API key</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.CreatedKey))
{
    <div class="alert alert-success">
        <div class="fw-semibold">New key created.</div>
        <code>@Model.CreatedKey</code>
    </div>
}

<table class="table table-striped align-middle">
    <thead>
    <tr><th>Name</th><th>Slack bot</th><th>API key</th><th>Active</th><th>Last used</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var item in Model.ApiKeys)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.ProjectName</td>
            <td>
                @if (!string.IsNullOrWhiteSpace(item.ApiKey))
                {
                    <div class="d-flex gap-2 align-items-center">
                        <code class="api-key-value">@item.ApiKey</code>
                        <button class="btn btn-sm btn-outline-secondary" type="button" data-copy="@item.ApiKey">Copy</button>
                    </div>
                }
                else
                {
                    <span class="text-muted">Unavailable for older hashed-only key: <code>@item.KeyPrefix...</code></span>
                }
            </td>
            <td>@item.IsActive</td>
            <td>@item.LastUsedAtUtc</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@item.Id">Edit</a>
                <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
    <script>
        document.querySelectorAll("[data-copy]").forEach((button) => {
            button.addEventListener("click", async () => {
                await navigator.clipboard.writeText(button.dataset.copy);
                const originalText = button.textContent;
                button.textContent = "Copied";
                window.setTimeout(() => button.textContent = originalText, 1200);
            });
        });
    </script>
}
