@page
@model SlackBridge.Web.Pages.Admin.Projects.IndexModel
@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Projects</h1>
    <a class="btn btn-primary" asp-page="Create">New project</a>
</div>

<table class="table table-striped align-middle">
    <thead>
    <tr><th>Name</th><th>Description</th><th>Slack</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Projects)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Description</td>
            <td>@(string.IsNullOrWhiteSpace(item.SlackWebhookUrl) ? "Missing" : "Configured")</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@item.Id">Edit</a>
                <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
