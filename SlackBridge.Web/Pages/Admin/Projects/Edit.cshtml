@page "{id:int}"
@model SlackBridge.Web.Pages.Admin.Projects.EditModel
@{
    ViewData["Title"] = "Edit Slack bot";
}

<h1>Edit Slack bot</h1>
<form method="post" class="col-lg-6">
    <input type="hidden" asp-for="Project.Id" />
    <input type="hidden" asp-for="Project.CustomerInstanceId" />
    <input type="hidden" asp-for="Project.CreatedAtUtc" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Project.Name" class="form-label"></label>
        <input asp-for="Project.Name" class="form-control" />
        <span asp-validation-for="Project.Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Project.Description" class="form-label"></label>
        <textarea asp-for="Project.Description" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label asp-for="Project.SlackWebhookUrl" class="form-label">Slack webhook URL</label>
        <input asp-for="Project.SlackWebhookUrl" class="form-control" placeholder="https://hooks.slack.com/services/..." />
        <span asp-validation-for="Project.SlackWebhookUrl" class="text-danger"></span>
    </div>
    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn btn-link" asp-page="Details" asp-route-id="@Model.Project.Id">Cancel</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
